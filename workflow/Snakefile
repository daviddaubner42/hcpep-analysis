rule create_raw_fc:
    input:
        os.path.join(outdir, "intermediaries", "to_delete.pkl"),
        os.path.join(rawdir, "xcp_d", "sub-{subid}", "ses-1", "func", "sub-{subid}_ses-1_task-rest_dir-AP_space-fsLR_seg-Glasser_den-91k_stat-mean_timeseries.ptseries.nii"),
        os.path.join(rawdir, "xcp_d", "sub-{subid}", "ses-1", "func", "sub-{subid}_ses-1_task-rest_dir-PA_space-fsLR_seg-Glasser_den-91k_stat-mean_timeseries.ptseries.nii"),
        os.path.join(rawdir, "xcp_d", "sub-{subid}", "ses-2", "func", "sub-{subid}_ses-2_task-rest_dir-AP_space-fsLR_seg-Glasser_den-91k_stat-mean_timeseries.ptseries.nii"),
        os.path.join(rawdir, "xcp_d", "sub-{subid}", "ses-2", "func", "sub-{subid}_ses-2_task-rest_dir-PA_space-fsLR_seg-Glasser_den-91k_stat-mean_timeseries.ptseries.nii")
    params:
        rawdir = rawdir,
        workflowdir = workflowdir,
        outdir = outdir
    output:
        expand(os.path.join(outdir, "results", "static", "sub-{{subid}}", "sub-{{subid}}_FC_{thread}_raw.csv"), thread=threads)
    conda:
        os.path.join(environmentdir, "environment.yaml")
    shell:
        "mkdir -p {params.outdir}/results/static/sub-{wildcards.subid} && "
        "python {params.workflowdir}/scripts/create_raw_fc.py --ts_dir {params.rawdir}/xcp_d/sub-{wildcards.subid} --subid {wildcards.subid} --excluded_rois_path {input[0]} --out_dir {params.outdir}/results/static/sub-{wildcards.subid}"

rule regress_confounds:
    input:
        expand(os.path.join(outdir, "results", "static", "sub-{subid}", "sub-{subid}_FC_{{thread}}_raw.csv"), subid=subids),
        demo=os.path.join(resourcedir, "ndar_subject01.txt")
    params:
        workflowdir = workflowdir,
        outdir = outdir,
        fcdir = os.path.join(outdir, "results", "static"),
        subids=subids
    resources:
        mem='32G',
        time='06:00:00'
    output:
        expand(os.path.join(outdir, "results", "static", "sub-{subid}", "sub-{subid}_FC_{{thread}}_regr.csv"), subid=subids)
    conda:
        os.path.join(environmentdir, "environment.yaml")
    shell:
        "python {params.workflowdir}/scripts/regress_confounds.py --fc_dir {params.fcdir} --thread {wildcards.thread} --subids {params.subids} --demo_data_path {input.demo}"

rule pairwise_comparison:
    input:
        expand(os.path.join(outdir, "results", "static", "sub-{subid}", "sub-{subid}_FC_{{thread}}_regr.csv"), subid=subids),
        demo=os.path.join(resourcedir, "ndar_subject01.txt")
    params:
        workflowdir = workflowdir,
        outdir = outdir,
        fcdir = os.path.join(outdir, "results", "static"),
        subids=subids
    resources:
        mem='32G',
        time='06:00:00'
    output:
        os.path.join(outdir, "results", "static", "{thread}_avg_patient_fc.csv"),
        os.path.join(outdir, "results", "static", "{thread}_avg_hc_fc.csv"),
        os.path.join(outdir, "results", "static", "{thread}_p_vals.csv"),
        os.path.join(outdir, "results", "static", "{thread}_p_vals_fdr.csv"),
        os.path.join(outdir, "results", "static", "{thread}_stats.csv")
    conda:
        os.path.join(environmentdir, "environment.yaml")
    shell:
        "python {params.workflowdir}/scripts/pairwise_comparison.py --fc_dir {params.fcdir} --thread {wildcards.thread} --subids {params.subids} --demo_data_path {input.demo}"

rule reorder_to_networks:
    input:
        os.path.join(outdir, "results", "static", "{thread}_avg_patient_fc.csv"),
        os.path.join(outdir, "results", "static", "{thread}_avg_hc_fc.csv"),
        os.path.join(outdir, "results", "static", "{thread}_p_vals.csv"),
        os.path.join(outdir, "results", "static", "{thread}_p_vals_fdr.csv"),
        os.path.join(outdir, "results", "static", "{thread}_stats.csv"),
        networks=os.path.join(outdir, "intermediaries", "network_idxs.pkl")
    params:
        workflowdir = workflowdir,
        outdir = outdir,
        fcdir = os.path.join(outdir, "results", "static")
    output:
        os.path.join(outdir, "results", "static", "{thread}_avg_patient_fc_reordered.csv"),
        os.path.join(outdir, "results", "static", "{thread}_avg_hc_fc_reordered.csv"),
        os.path.join(outdir, "results", "static", "{thread}_p_vals_reordered.csv"),
        os.path.join(outdir, "results", "static", "{thread}_p_vals_fdr_reordered.csv"),
        os.path.join(outdir, "results", "static", "{thread}_stats_reordered.csv")
    conda:
        os.path.join(environmentdir, "environment.yaml")
    shell:
        "python {params.workflowdir}/scripts/reorder_to_networks.py --results_dir {params.fcdir} --network_path {input.networks} --thread {wildcards.thread}"

rule plot_pairwise_comparison:
    input:
        os.path.join(outdir, "results", "static", "{thread}_avg_patient_fc_reordered.csv"),
        os.path.join(outdir, "results", "static", "{thread}_avg_hc_fc_reordered.csv"),
        os.path.join(outdir, "results", "static", "{thread}_p_vals_reordered.csv"),
        os.path.join(outdir, "results", "static", "{thread}_p_vals_fdr_reordered.csv"),
        os.path.join(outdir, "results", "static", "{thread}_stats_reordered.csv"),
        demo=os.path.join(resourcedir, "ndar_subject01.txt"),
        networks=os.path.join(outdir, "intermediaries", "networks.pkl")
    params:
        workflowdir = workflowdir,
        outdir = outdir,
        fcdir = os.path.join(outdir, "results", "static"),
        subids=subids
    output:
        os.path.join(outdir, "results", "static", "images", "{thread}_avg_fc_comparison.png"),
        os.path.join(outdir, "results", "static", "images", "{thread}_p_vals_uncorrected.png"),
        os.path.join(outdir, "results", "static", "images", "{thread}_p_vals_fdr.png")
    conda:
        os.path.join(environmentdir, "environment.yaml")
    shell:
        "python {params.workflowdir}/scripts/plot_pairwise_comparison.py --fc_dir {params.fcdir} --thread {wildcards.thread} --subids {params.subids} --demo_data_path {input.demo} --network_path {input.networks}"

