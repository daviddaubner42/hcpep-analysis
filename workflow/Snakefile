rule create_FCDs:
    input:
        os.path.join(outdir, "results", "dynamic", "sub-{subid}", "sub-{subid}_windowed_FCs_{thread}.pkl")
    params:
        workflowdir = workflowdir,
        outdir = outdir,
        fcdir = os.path.join(outdir, "results", "dynamic"),
        subids=subids
    resources:
        mem='32G',
        time='06:00:00'
    output:
        os.path.join(outdir, "results", "dynamic", "sub-{subid}", "sub-{subid}_FCD_{thread}.csv"),
        os.path.join(outdir, "results", "dynamic", "sub-{subid}", "sub-{subid}_FCD_hist_{thread}.csv")
    conda:
        os.path.join(environmentdir, "environment.yaml")
    shell:
        "python {params.workflowdir}/scripts/create_FCDs.py --windowed_fc_path {input} --out_dir {params.outdir}/results/dynamic/sub-{wildcards.subid} --subid {wildcards.subid} --thread {wildcards.thread}"

rule aggregate_FCDs:
    input:
        expand(os.path.join(outdir, "results", "dynamic", "sub-{subid}", "sub-{subid}_FCD_{{thread}}.csv"), subid=subids),
        expand(os.path.join(outdir, "results", "dynamic", "sub-{subid}", "sub-{subid}_FCD_hist_{{thread}}.csv"), subid=subids),
        demo=os.path.join(resourcedir, "ndar_subject01.txt")
    params:
        workflowdir = workflowdir,
        outdir = outdir,
        subids=subids
    resources:
        mem='32G',
        time='06:00:00'
    output:
        os.path.join(outdir, "results", "dynamic", "FCDs_{thread}.pkl"),
        os.path.join(outdir, "results", "dynamic", "FCD_hists_{thread}.pkl"),
        os.path.join(outdir, "results", "dynamic", "FCD_hists_regr_{thread}.pkl")
    conda:
        os.path.join(environmentdir, "environment.yaml")
    shell:
        "python {params.workflowdir}/scripts/aggregate_FCDs.py --fcds_path {params.outdir}/results/dynamic/ --subids {params.subids} --thread {wildcards.thread} --demo_data_path {input.demo}"

rule plot_FCDs:
    input:
        os.path.join(resourcedir, "ndar_subject01.txt"),
        os.path.join(outdir, "results", "dynamic", "FCDs_{thread}.pkl"),
        os.path.join(outdir, "results", "dynamic", "FCD_hists_{thread}.pkl"),
        os.path.join(outdir, "results", "dynamic", "FCD_hists_regr_{thread}.pkl")
    params:
        workflowdir = workflowdir,
        outdir = outdir,
        subids=subids
    resources:
        mem='32G',
        time='06:00:00'
    output:
        os.path.join(outdir, "results", "dynamic", "images", "avg_FCD_comparison_{thread}.png"),
        os.path.join(outdir, "results", "dynamic", "images", "avg_FCD_hist_comparison_{thread}.png"),
        os.path.join(outdir, "results", "dynamic", "images", "avg_FCD_hist_comparison_regr_{thread}.png")
    conda:
        os.path.join(environmentdir, "environment.yaml")
    shell:
        "mkdir -p {params.outdir}/results/dynamic/images && "
        "python {params.workflowdir}/scripts/plot_FCDs.py --fcds_path {params.outdir}/results/dynamic/ --thread {wildcards.thread} --subids {params.subids} --demo_data_path {input[0]}"

