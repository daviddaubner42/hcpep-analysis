rule create_windowed_fcs:
    input:
        os.path.join(outdir, "intermediaries", "to_delete.pkl"),
        os.path.join(rawdir, "xcp_d", "sub-{subid}", "ses-1", "func", "sub-{subid}_ses-1_task-rest_dir-AP_space-fsLR_seg-Glasser_den-91k_stat-mean_timeseries.ptseries.nii"),
        os.path.join(rawdir, "xcp_d", "sub-{subid}", "ses-1", "func", "sub-{subid}_ses-1_task-rest_dir-PA_space-fsLR_seg-Glasser_den-91k_stat-mean_timeseries.ptseries.nii"),
        os.path.join(rawdir, "xcp_d", "sub-{subid}", "ses-2", "func", "sub-{subid}_ses-2_task-rest_dir-AP_space-fsLR_seg-Glasser_den-91k_stat-mean_timeseries.ptseries.nii"),
        os.path.join(rawdir, "xcp_d", "sub-{subid}", "ses-2", "func", "sub-{subid}_ses-2_task-rest_dir-PA_space-fsLR_seg-Glasser_den-91k_stat-mean_timeseries.ptseries.nii")
    params:
        rawdir = rawdir,
        workflowdir = workflowdir,
        outdir = outdir,
        window_size = config["window_size"],
        step_size = config["step_size"]
    resources:
        mem='32G',
        time='06:00:00'
    output:
        expand(os.path.join(outdir, "results", "dynamic", "sub-{{subid}}", "sub-{{subid}}_windowed_FCs_{thread}.pkl"), thread=threads)
    conda:
        os.path.join(environmentdir, "environment.yaml")
    shell:
        "mkdir -p {params.outdir}/results/dynamic/sub-{wildcards.subid} && "
        "python {params.workflowdir}/scripts/create_windowed_fcs.py --ts_dir {params.rawdir}/xcp_d/sub-{wildcards.subid} --subid {wildcards.subid} --excluded_rois_path {input[0]} --out_dir {params.outdir}/results/dynamic/sub-{wildcards.subid} --window_size {params.window_size} --step_size {params.step_size}"

