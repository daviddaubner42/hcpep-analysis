rule create_networks:
    input:
        seg=os.path.join(rawdir, "xcp_d/atlases/atlas-Glasser/atlas-Glasser_dseg.tsv"),
        ts=os.path.join(rawdir, "xcp_d", f"sub-{subids[0]}", "ses-1", "func", f"sub-{subids[0]}_ses-1_task-rest_dir-AP_space-fsLR_seg-Glasser_den-91k_stat-mean_timeseries.ptseries.nii")
    params:
        resourcedir = resourcedir,
        workflowdir = workflowdir,
        outdir = outdir
    output:
        os.path.join(outdir, "intermediaries", "networks.pkl"),
        os.path.join(outdir, "intermediaries", "network_idxs.pkl"),
        os.path.join(outdir, "intermediaries", "partition.pkl"),
        os.path.join(outdir, "intermediaries", "partition_idxs.pkl"),
        os.path.join(outdir, "intermediaries", "to_delete.pkl"),
        os.path.join(outdir, "intermediaries", "labels.pkl"),
    conda:
        os.path.join(environmentdir, "environment.yaml")
    shell:
        "mkdir -p {params.outdir}/intermediaries && "
        "python {params.workflowdir}/scripts/create_networks.py --seg_file {input.seg} --ts {input.ts} --out_dir {params.outdir}/intermediaries --community 'yeo'"

