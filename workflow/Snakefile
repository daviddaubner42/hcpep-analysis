import os

configfile: "config/config.yaml"
report: "workflow.rst"

rawdir = os.path.join(config["datadir"]) # the directory with derivatives to be analysed
outdir = config["outdir"] # the directory where results are to be stored

environmentdir = os.path.join(config["rootdir"], "envs")
resourcedir = os.path.join(config["rootdir"], "resources")
workflowdir = os.path.join(config["rootdir"], "workflow")

# Create the results directory if it doesn't exist already
os.makedirs(outdir, exist_ok=True)

# Specifies the files which should exist at the end of the processing
endfiles = [
    # os.path.join(outdir, "results", "static", "images", "avg_fc_comparison.png"),
    # os.path.join(outdir, "results", "static", "images", "p_vals_uncorrected.png"),
    # os.path.join(outdir, "results", "static", "images", "p_vals_fdr.png"),
    # os.path.join(outdir, "results", "dynamic", "images", "avg_FCD_comparison.png"),
    # os.path.join(outdir, "results", "dynamic", "images", "avg_FCD_hist_comparison.png"),
    # os.path.join(outdir, "results", "dynamic", "images", "avg_FCD_hist_comparison_regr.png"),
    # os.path.join(outdir, "results", "graph_theory", "global", "images", "global_metric_comparison.png"),
    # os.path.join(outdir, "results", "graph_theory", "local", "{metric}_ps_stats.csv")
    os.path.join(outdir, "results", "static", "images", "{thread}_avg_fc_comparison.png"),
    os.path.join(outdir, "results", "static", "images", "{thread}_p_vals_uncorrected.png"),
    os.path.join(outdir, "results", "static", "images", "{thread}_p_vals_fdr.png"),
    os.path.join(outdir, "results", "dynamic", "images", "avg_FCD_comparison_{thread}.png"),
    os.path.join(outdir, "results", "dynamic", "images", "avg_FCD_hist_comparison_{thread}.png"),
    os.path.join(outdir, "results", "dynamic", "images", "avg_FCD_hist_comparison_regr_{thread}.png"),
    os.path.join(outdir, "results", "graph_theory", "global", "images", "global_metric_comparison_{thread}.png"),
    os.path.join(outdir, "results", "graph_theory", "local", "{metric}_ps_stats_{thread}.csv")
]

# Define the subject IDs to be processed
subids = [subid[4:] for subid in os.listdir(os.path.join(rawdir, "xcp_d")) if os.path.exists(os.path.join(rawdir, "xcp_d", f"{subid}", "ses-1", "func", f"{subid}_ses-1_task-rest_dir-AP_space-fsLR_seg-Glasser_den-91k_stat-mean_timeseries.ptseries.nii"))]

local_metrics = ["betweenness_centrality", "degree_centrality", "clustering_coefficient", "avg_shortest_path_length"]
threads = ["mean", "ses-1_mean", "ses-2_mean", "ses-1_dir-AP", "ses-1_dir-PA", "ses-2_dir-AP", "ses-2_dir-PA"]

rule all:
    """
    Generates all required outputs
    """
    input:
        expand(endfiles, subid=subids, metric=local_metrics, thread=threads)

""" ------------------------------------------- """
""" ---------------- The rules ---------------- """
""" ------------------------------------------- """

