""" Global metrics """

rule calculate_avg_clustering:
    input:
        os.path.join(outdir, "results", "static", "sub-{subid}", "sub-{subid}_FC_{thread}_raw.csv"),
        os.path.join(outdir, "intermediaries", "labels.pkl")
    params:
        workflowdir = workflowdir,
        outdir = outdir,
        min_density = config["min_density"],
        max_density = config["max_density"],
        density_step = config["density_step"]
    resources:
        mem='16G',
        time='02:00:00'
    output:
        os.path.join(outdir, "results", "graph_theory", "global", "sub-{subid}", "sub-{subid}_avg_clustering_{thread}.pkl")
    conda:
        os.path.join(environmentdir, "environment.yaml")
    shell:
        "mkdir -p {params.outdir}/results/graph_theory/global/sub-{wildcards.subid} && "
        "python {params.workflowdir}/scripts/calculate_avg_clustering.py --input_path {input[0]} --out_path {output} --min_density {params.min_density} --max_density {params.max_density} --density_step {params.density_step} --labels_path {input[1]}"

