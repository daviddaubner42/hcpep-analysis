rule calculate_robustness_random:
    input:
        os.path.join(outdir, "results", "static", "sub-{subid}", "sub-{subid}_FC_{thread}_raw.csv"),
        os.path.join(outdir, "intermediaries", "labels.pkl")
    params:
        workflowdir = workflowdir,
        outdir = outdir,
        min_density = config["min_density"],
        max_density = config["max_density"],
        density_step = config["density_step"]
    resources:
        mem='32G',
        time='04:00:00'
    output:
        os.path.join(outdir, "results", "graph_theory", "global", "sub-{subid}", "sub-{subid}_robustness_random_{thread}.pkl")
    conda:
        os.path.join(environmentdir, "environment.yaml")
